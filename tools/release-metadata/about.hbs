<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Qwen3-TTS Native Rust third-party licenses</title>
  <style>
    body { color: #172033; font: 16px/1.55 system-ui, sans-serif; margin: 2rem auto; max-width: 76rem; padding: 0 1.5rem; }
    h1, h2, h3 { line-height: 1.2; }
    section { border-top: 1px solid #ccd3df; margin-top: 2.5rem; padding-top: 1.5rem; }
    pre { background: #f4f6f9; border: 1px solid #dfe4ec; overflow-wrap: anywhere; padding: 1rem; white-space: pre-wrap; }
    code { background: #f4f6f9; padding: 0.1rem 0.3rem; }
  </style>
</head>
<body>
  <main>
    <h1>Rust third-party licenses</h1>
    <p>
      This report was generated by <code>cargo-about</code> from the locked
      <code>qwen3-tts-server</code> release graph for
      <code>aarch64-unknown-linux-gnu</code>. Development-only dependencies and
      local first-party path packages are not listed as third parties.
    </p>
{{#each licenses}}
    <section class="license" id="{{id}}">
      <h2>{{name}} ({{id}})</h2>
      <h3>Used by</h3>
      <ul>
{{#each used_by}}
{{#if crate.source}}
        <li data-source="{{crate.source}}">
{{#if crate.repository}}
          <a href="{{crate.repository}}">{{crate.name}} {{crate.version}}</a>
{{else}}
          {{crate.name}} {{crate.version}}
{{/if}}
        </li>
{{/if}}
{{/each}}
      </ul>
      <pre>{{text}}</pre>
    </section>
{{/each}}
  </main>
</body>
</html>
